# 复制为 .env 或由部署平台注入运行时环境变量。
# 不要在真实项目仓库中提交 .env / .env.production。

# 模型服务
DASHSCOPE_API_KEY=replace-with-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RAG_CHAT_MODEL=qwen-plus
RAG_EMBEDDING_MODEL=text-embedding-v4
RAG_VECTOR_DIMENSIONS=1024
RAG_RERANK_ENABLED=true
RAG_RERANK_MODEL=qwen3-rerank

# API 认证
RAG_API_KEY=replace-with-long-random-api-key

# 数据库
RAG_POSTGRES_DSN=postgresql+psycopg://db_user:db_password@db_host:5432/rag
RAG_MEDICAL_POSTGRES_DSN=postgresql+psycopg://db_user:db_password@db_host:5432/rag_medical
RAG_MEDICAL_ADMIN_POSTGRES_DSN=postgresql://db_user:db_password@db_host:5432/postgres
RAG_MEDICAL_DATABASE_NAME=rag_medical

# 向量库 / 混合检索
RAG_VECTOR_COLLECTION_NAME=rag_chunks
RAG_MEDICAL_VECTOR_TABLE=medical_rag_chunks
RAG_MEDICAL_AUDIT_TABLE=medical_rag_audit
RAG_MEDICAL_DEFAULT_PDF_PATH=中医临床诊疗智能助手.pdf
RAG_MEDICAL_QUERY_REWRITE_COUNT=3
RAG_MEDICAL_TEXT_SEARCH_CONFIG=jiebacfg

# 切分和召回
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_CANDIDATE_K=24
RAG_FINAL_K=6
RAG_MIN_SCORE=0.0

# Ragas 评估脚本
RAGAS_API_BASE_URL=http://127.0.0.1:8000
RAGAS_TENANT_ID=default
RAGAS_JUDGE_MODEL=qwen-plus
RAGAS_EVAL_CASES_FILE=evals/datasets/medical_ragas_cases.example.jsonl
RAGAS_EVAL_OUTPUT_DIR=evals/experiments

# Langfuse 可观测性手动验证
LANGFUSE_SECRET_KEY=replace-with-langfuse-secret-key
LANGFUSE_PUBLIC_KEY=replace-with-langfuse-public-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_RUN_QUICKSTART=false
LANGFUSE_RUN_QWEN_PLUS_QUICKSTART=false
